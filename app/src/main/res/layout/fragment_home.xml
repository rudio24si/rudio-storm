<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".pertemuan_7.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvMenuTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Main Menu"
            android:textAlignment="center"
            android:textColor="#121212"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih layanan digital desa"
            android:textAlignment="center"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRumus"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3F51B5"
            android:text="Rumus Bangun Ruang"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCustom1"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3F51B5"
            android:text="Halaman Custom 1"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_view"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCustom2"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3F51B5"
            android:text="Halaman Custom 2"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCustom3"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3F51B5"
            android:text="Kamar"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#B71C1C"
            android:text="Logout (Kembali Login)"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:elevation="4dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTerbaru"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Terbaru" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPenting"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Penting" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBelumDibaca"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum Dibaca" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.0.0 - Rudio Dev"
            android:textAlignment="center"
            android:layout_marginTop="40dp"
            android:textColor="#666666"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>