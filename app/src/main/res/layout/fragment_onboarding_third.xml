<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3F51B5"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/imgOnboarding3"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:src="@android:drawable/ic_lock_lock"
        android:contentDescription="Slide 3 Image" />

    <TextView
        android:id="@+id/tvTitle3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Mulai Membaca Sekarang"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/tvDescription3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Silakan masuk ke akun Anda untuk mempersonalisasi topik berita yang Anda sukai."
        android:textColor="#E0E0E0"
        android:textSize="16sp"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:backgroundTint="#FFFFFF"
        android:text="Ayo Mulai"
        android:textColor="#3F51B5"
        android:textStyle="bold" />

</LinearLayout>